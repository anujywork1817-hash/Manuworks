# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Application
APP_NAME=LexDocs
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docassist
POSTGRES_PASSWORD=change_me
POSTGRES_DB=docassist_db
POSTGRES_SSL_MODE=disable

# Redis (optional — app works without it)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change_me

# JWT — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change_me_to_a_random_secret
JWT_REFRESH_SECRET=change_me_to_another_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Gemini AI — get key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI (primary AI provider — get key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq (secondary/fallback AI provider — used automatically when OpenAI is unset or rate-limited)
GROQ_API_KEY=your_groq_api_key_here

# Qdrant (optional — app works without it)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# File Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
STORAGE_MAX_FILE_SIZE=52428800

# OCR
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng

# Email (optional — needed for forgot password only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=LexDocs

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_REQUESTS=100